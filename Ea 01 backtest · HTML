<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>バックテスト結果 | ミドルレンジのつもりですが、なにか？</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#080e1f;
    --bg2:#0d1530;
    --accent:#00c4ff;
    --accent2:#00ff9d;
    --accent-red:#ff4060;
    --text:#e2e8f0;
    --text-muted:#b0c4d8;
    --text-dim:#8ba8c4;
    --border:rgba(0,196,255,0.15);
    --card-bg:rgba(8,20,50,0.82);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--text);font-family:'Noto Sans JP',sans-serif;font-weight:300;line-height:1.8;min-height:100vh;overflow-x:hidden;}
  #bg{position:fixed;inset:0;z-index:0;}
  .container{position:relative;z-index:1;max-width:860px;margin:0 auto;padding:60px 24px 80px;}
  .back-link{display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);font-size:13px;text-decoration:none;border-bottom:none;margin-bottom:40px;opacity:0.7;transition:opacity 0.2s;}
  .back-link:hover{opacity:1;}
  .header{text-align:center;margin-bottom:48px;animation:fadeUp 0.8s ease both;}
  .header-badge{display:inline-block;background:rgba(0,196,255,0.1);border:1px solid rgba(0,196,255,0.3);color:var(--accent);font-size:11px;letter-spacing:0.2em;padding:5px 14px;border-radius:4px;margin-bottom:20px;font-family:'Noto Serif JP',serif;text-transform:uppercase;}
  h1{font-family:'Noto Serif JP',serif;font-weight:600;font-size:clamp(17px,3.5vw,24px);line-height:1.6;letter-spacing:0.04em;margin-bottom:8px;color:var(--text);}
  .header-sub{color:var(--text-muted);font-size:13px;letter-spacing:0.05em;}
  .section{margin-bottom:22px;animation:fadeUp 0.7s ease both;}
  .section:nth-child(2){animation-delay:0.08s}.section:nth-child(3){animation-delay:0.16s}
  .section:nth-child(4){animation-delay:0.24s}.section:nth-child(5){animation-delay:0.32s}
  .section-label{display:flex;align-items:center;gap:10px;font-size:11px;letter-spacing:0.18em;color:var(--accent);text-transform:uppercase;margin-bottom:12px;font-weight:500;}
  .section-label::after{content:'';flex:1;height:1px;background:var(--border);}
  .card{background:var(--card-bg);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid var(--border);border-radius:8px;padding:22px 26px;box-shadow:0 4px 24px rgba(0,0,0,0.4);}
  .card-cyan {border-left:3px solid var(--accent);}
  .card-green{border-left:3px solid var(--accent2);}
  .card-amber{border-left:3px solid #f59e0b;}
  h2{font-family:'Noto Serif JP',serif;font-size:16px;font-weight:600;margin-bottom:14px;color:var(--text);}
  .info-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
  @media(max-width:500px){.info-grid{grid-template-columns:1fr;}}
  .info-item{background:rgba(0,196,255,0.05);border:1px solid rgba(0,196,255,0.12);border-radius:6px;padding:10px 14px;}
  .info-label{font-size:11px;color:#b0c4d8;margin-bottom:2px;letter-spacing:0.05em;}
  .info-value{font-size:14px;color:#e8f0f8;font-weight:500;}
  .info-value.green{color:var(--accent2);}
  .info-value.red{color:var(--accent-red);}
  .info-value.cyan{color:var(--accent);}
  .result-img{width:100%;border-radius:6px;border:1px solid var(--border);box-shadow:0 2px 12px rgba(0,0,0,0.4);display:block;}
  .warn-box{background:rgba(245,158,11,0.07);border:1px solid rgba(245,158,11,0.25);border-radius:6px;padding:12px 16px;margin-top:14px;display:flex;gap:10px;align-items:flex-start;}
  .warn-icon{flex-shrink:0;font-size:15px;}
  .warn-text{font-size:12px;color:#d97706;line-height:1.75;}
  .summary-card{background:var(--card-bg);backdrop-filter:blur(14px);border:1px solid rgba(0,196,255,0.2);border-radius:8px;padding:24px 28px;text-align:center;box-shadow:0 4px 24px rgba(0,0,0,0.4);}
  .summary-card p{font-size:14px;color:var(--text-muted);line-height:1.9;}
  a{color:var(--accent);text-decoration:none;border-bottom:1px solid rgba(0,196,255,0.3);}
  a:hover{border-color:var(--accent);}
  strong{color:var(--text);font-weight:500;}
  @keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
  @media(max-width:500px){.card{padding:16px 14px}}
</style>
</head>
<body>
<canvas id="bg"></canvas>
<div class="container">
  <a href="ea_01.html" class="back-link">← EA詳細へ戻る</a>
  <div class="header">
    <div class="header-badge">Backtest Results</div>
    <h1>ミドルレンジのつもりですが、なにか？</h1>
    <p class="header-sub">GOLDmicro / M5 / 2015.01.01 〜 2026.05.03</p>
  </div>

  <!-- テスト条件 -->
  <div class="section">
    <div class="section-label">01 — Test Conditions</div>
    <div class="card card-cyan">
      <h2>テスト条件</h2>
      <div class="info-grid">
        <div class="info-item"><div class="info-label">銘柄</div><div class="info-value cyan">GOLDmicro</div></div>
        <div class="info-item"><div class="info-label">期間</div><div class="info-value">M5（2015.01.01〜2026.05.03）</div></div>
        <div class="info-item"><div class="info-label">会社</div><div class="info-value">FinTrade Limited</div></div>
        <div class="info-item"><div class="info-label">初期証拠金</div><div class="info-value">100,000</div></div>
        <div class="info-item"><div class="info-label">レバレッジ</div><div class="info-value">1:1000</div></div>
        <div class="info-item"><div class="info-label">ヒストリー品質</div><div class="info-value cyan">99%</div></div>
      </div>
    </div>
  </div>

  <!-- 主要結果 -->
  <div class="section">
    <div class="section-label">02 — Key Results</div>
    <div class="card card-green">
      <h2>主要結果</h2>
      <div class="info-grid">
        <div class="info-item"><div class="info-label">総損益</div><div class="info-value green">897,760</div></div>
        <div class="info-item"><div class="info-label">プロフィットファクター</div><div class="info-value cyan">2.06</div></div>
        <div class="info-item"><div class="info-label">勝率（全体）</div><div class="info-value green">72.13%</div></div>
        <div class="info-item"><div class="info-label">リカバリファクター</div><div class="info-value cyan">6.48</div></div>
        <div class="info-item"><div class="info-label">残高最大ドローダウン</div><div class="info-value red">48,255（8%）</div></div>
        <div class="info-item"><div class="info-label">証拠金最大ドローダウン</div><div class="info-value red">138,613（18%）</div></div>
        <div class="info-item"><div class="info-label">取引数</div><div class="info-value">9,201</div></div>
        <div class="info-item"><div class="info-label">証拠金維持率</div><div class="info-value cyan">5,374.39%</div></div>
      </div>
      <div class="warn-box">
        <div class="warn-icon">⚠️</div>
        <div class="warn-text">バックテストはあくまで過去データに基づくシミュレーションです。将来の利益を保証するものではありません。特に昨今のGOLDの異常ボラティリティ期間を含むデータとして参考にしてください。</div>
      </div>
    </div>
  </div>

  <!-- バックテスト画像 -->
  <div class="section">
    <div class="section-label">03 — Backtest Report</div>
    <div class="card card-amber">
      <h2>バックテストレポート（MT5）　ナンピンフィルター ON　＊他はデフォルト値のまま</h2>
      <img class="result-img" src="data:image/png;base64," alt="バックテスト結果レポート">
    </div>
  </div>

  <div class="section">
    <div class="summary-card">
      <p>ご質問は<strong>公式 LINE</strong> よりお気軽にどうぞ。</p>
    </div>
  </div>
</div>

<script>
const canvas = document.getElementById('bg');
const ctx = canvas.getContext('2d');
function resize(){
  canvas.width = window.innerWidth;
  canvas.height = Math.max(window.innerHeight, document.body.scrollHeight);
}
resize();
window.addEventListener('resize', resize);

// ローソク足データ生成
function generateCandles(n, startPrice, volatility) {
  const candles = [];
  let price = startPrice;
  for(let i = 0; i < n; i++) {
    const open = price;
    const change = (Math.random() - 0.48) * volatility;
    const close = open + change;
    const high = Math.max(open, close) + Math.random() * volatility * 0.5;
    const low  = Math.min(open, close) - Math.random() * volatility * 0.5;
    candles.push({ open, close, high, low });
    price = close;
  }
  return candles;
}

// 複数列のローソク足データ
const candleSets = [];
const numSets = 6;
for(let i = 0; i < numSets; i++) {
  candleSets.push(generateCandles(80, 1800 + Math.random() * 400, 12 + Math.random() * 8));
}

function drawBackground(t) {
  const W = canvas.width, H = canvas.height;

  // ダークネイビー背景グラデーション
  const bg = ctx.createLinearGradient(0, 0, W, H);
  bg.addColorStop(0, '#060c1a');
  bg.addColorStop(0.5, '#080e20');
  bg.addColorStop(1, '#060c1a');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // グリッド線
  ctx.strokeStyle = 'rgba(0,196,255,0.04)';
  ctx.lineWidth = 1;
  const gridX = 60, gridY = 40;
  for(let x = 0; x < W; x += gridX) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
  }
  for(let y = 0; y < H; y += gridY) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }

  // ローソク足を複数列で描画
  const speed = t * 0.0045;
  for(let s = 0; s < numSets; s++) {
    const candles = candleSets[s];
    const colW = W / numSets;
    const startX = s * colW;
    const candleW = colW / candles.length;
    const offsetX = (speed * 6 * (s % 2 === 0 ? 1 : -1)) % (candleW * candles.length);

    // 価格範囲
    const prices = candles.flatMap(c => [c.high, c.low]);
    const minP = Math.min(...prices), maxP = Math.max(...prices);
    const priceRange = maxP - minP || 1;

    const zoneH = H * (0.15 + (s % 3) * 0.12);
    const zoneY = (s < 3 ? 0 : H - zoneH);
    const alpha = 0.18 + Math.sin(t * 0.0005 + s) * 0.06;

    candles.forEach((c, i) => {
      const x = startX + ((i * candleW - offsetX + colW * candles.length) % (colW * candles.length));
      if(x < startX - candleW || x > startX + colW + candleW) return;

      const isUp = c.close >= c.open;
      const color = isUp ? `rgba(0,255,157,${alpha})` : `rgba(255,64,96,${alpha})`;

      const openY  = zoneY + (1 - (c.open  - minP) / priceRange) * zoneH;
      const closeY = zoneY + (1 - (c.close - minP) / priceRange) * zoneH;
      const highY  = zoneY + (1 - (c.high  - minP) / priceRange) * zoneH;
      const lowY   = zoneY + (1 - (c.low   - minP) / priceRange) * zoneH;

      ctx.strokeStyle = color;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x + candleW * 0.5, highY);
      ctx.lineTo(x + candleW * 0.5, lowY);
      ctx.stroke();

      ctx.fillStyle = color;
      const bodyY = Math.min(openY, closeY);
      const bodyH = Math.max(Math.abs(closeY - openY), 1);
      ctx.fillRect(x + 1, bodyY, candleW - 3, bodyH);
    });
  }

  // 右上に大きめのローソク足チャート（アクセント）
  {
    const candles = candleSets[0];
    const cW = Math.min(W * 0.38, 340);
    const cH = H * 0.22;
    const cX = W - cW - 10;
    const cY = 10;
    const candleW = cW / candles.length;
    const offsetX = (speed * 7.5) % (candleW * candles.length);
    const prices = candles.flatMap(c => [c.high, c.low]);
    const minP = Math.min(...prices), maxP = Math.max(...prices);
    const priceRange = maxP - minP || 1;

    candles.forEach((c, i) => {
      const x = cX + ((i * candleW - offsetX + cW * candles.length) % (cW * candles.length));
      if(x < cX - candleW || x > cX + cW + candleW) return;
      const isUp = c.close >= c.open;
      const alpha = 0.55;
      const color = isUp ? `rgba(0,255,157,${alpha})` : `rgba(255,64,96,${alpha})`;
      const openY  = cY + (1 - (c.open  - minP) / priceRange) * cH;
      const closeY = cY + (1 - (c.close - minP) / priceRange) * cH;
      const highY  = cY + (1 - (c.high  - minP) / priceRange) * cH;
      const lowY   = cY + (1 - (c.low   - minP) / priceRange) * cH;

      ctx.strokeStyle = color;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x + candleW * 0.5, highY);
      ctx.lineTo(x + candleW * 0.5, lowY);
      ctx.stroke();
      ctx.fillStyle = color;
      const bodyY = Math.min(openY, closeY);
      const bodyH = Math.max(Math.abs(closeY - openY), 1);
      ctx.fillRect(x + 1, bodyY, candleW - 3, bodyH);
    });

    // チャートエリアの枠線
    ctx.strokeStyle = 'rgba(0,196,255,0.12)';
    ctx.lineWidth = 1;
    ctx.strokeRect(cX, cY, cW, cH);
  }

  // 上部に青いグロー
  const topGlow = ctx.createLinearGradient(0, 0, 0, H * 0.3);
  topGlow.addColorStop(0, 'rgba(0,100,200,0.12)');
  topGlow.addColorStop(1, 'rgba(0,100,200,0)');
  ctx.fillStyle = topGlow;
  ctx.fillRect(0, 0, W, H * 0.3);

  // コンテンツ読みやすさのための暗幕
  ctx.fillStyle = 'rgba(6,12,26,0.55)';
  ctx.fillRect(0, 0, W, H);
}

let st = null;
function loop(ts) {
  if(!st) st = ts;
  drawBackground(ts - st);
  requestAnimationFrame(loop);
}
requestAnimationFrame(loop);
</script>
</body>
</html>
